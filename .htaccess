# ============================================================
# Store — Apache .htaccess
# ============================================================

# Disable directory listing (security: never expose file tree)
Options -Indexes

# Protect sensitive config files from direct browser access
<FilesMatch "\.(sql|log|env|json|md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Protect the config directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
    RewriteRule ^includes/ - [F,L]
</IfModule>

# Enable GZIP compression for faster page loads
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css         "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/svg+xml    "access plus 1 month"
    ExpiresByType image/jpeg       "access plus 1 month"
    ExpiresByType image/png        "access plus 1 month"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Prevent PHP errors from leaking sensitive information
php_flag display_errors Off
php_flag log_errors On

# Custom error pages
ErrorDocument 403 /pages/403.php
ErrorDocument 404 /pages/404.php
ErrorDocument 429 /pages/429.php
